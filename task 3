import numpy as np

def get_outgoing_edges(graph, representation, vertex):
    """
    adj_matrix - матрица смежности
    inc_matrix - матрица инцидентности
    adj_list - список смежности
    edges_list - список дуг
    ordered_edges - упорядоченный список дуг
    """

    result = []

    #матрица смежности
    if representation == 'adj_matrix':
        for j in range(graph.shape[1]):
            if graph[vertex][j] == 1:
                result.append((vertex, j))

    #матрица инцидентности
    elif representation == 'inc_matrix':
        for j in range(graph.shape[1]):
            if graph[vertex][j] == -1:
                to_vertex = np.where(graph[:, j] == 1)[0]
                if len(to_vertex) > 0:
                    result.append((int(vertex), int(to_vertex[0])))

    #список смежности
    elif representation == 'adj_list':
        for to_vertex in graph.get(vertex, []):
            result.append((vertex, to_vertex))

    #список дуг
    elif representation == 'edges_list':
        tails = graph['tails']
        heads = graph['heads']
        for i in range(len(tails)):
            if tails[i] == vertex:
                result.append((int(vertex), int(heads[i])))

    #упорядоченный список дуг
    elif representation == 'ordered_edges':
        S_arr = graph['S']
        heads = graph['heads_ordered']
        start = S_arr[vertex]
        end = S_arr[vertex + 1]
        for i in range(start, end):
            result.append((int(vertex), int(heads[i])))

    else:
        raise ValueError("Неизвестное представление")

    return set(result)


V = 5
m = 8

edges = [
    (0, 1),
    (0, 2),
    (0, 4),
    (1, 2),
    (1, 3),
    (1, 4),
    (3, 2),
    (4, 3)
]

#матрица смежности
adj_matrix = np.zeros((V, V))
for u, v in edges:
    adj_matrix[u][v] = 1

#матрица инцидентности
E = len(edges)
inc_matrix = np.zeros((V, E), dtype=int)
for j, (u, v) in enumerate(edges):
    inc_matrix[u][j] = -1
    inc_matrix[v][j] = 1

#список смежности
adj_list = {i: [] for i in range(V)}
for u, v in edges:
    adj_list[u].append(v)

#список дуг
tails = np.array([u for u, v in edges])
heads = np.array([v for u, v in edges])

# упорядоченный список дуг
list_of_edge = sorted(edges)
heads_ordered = np.array([v for u, v in list_of_edge])
S = np.full(V + 1, m, dtype=int)

for i in range(m):
    start_vertex = list_of_edge[i][0]
    if S[start_vertex] > i:
        S[start_vertex] = i

#тестирование
test_vertex = 1

#Матрица смежности
res = get_outgoing_edges(adj_matrix, 'adj_matrix', test_vertex)
print("Матрица смежности")
print(res)

# Матрица инцидентности
res = get_outgoing_edges(inc_matrix, 'inc_matrix', test_vertex)
print("Матрица инцидентности:")
print(f"{res}")

#Список смежности
res = get_outgoing_edges(adj_list, 'adj_list', test_vertex)
print("Список смежности:")
print(res)

#Список дуг
edges_dict = {'tails': tails, 'heads': heads}
res = get_outgoing_edges(edges_dict, 'edges_list', test_vertex)
print("Список дуг (два массива)")
print(res)

#Упорядоченный список дуг
ordered_dict = {'S': S, 'heads_ordered': heads_ordered}
res = get_outgoing_edges(ordered_dict, 'ordered_edges', test_vertex)
print("Упорядоченный список дуг")
print(res)



